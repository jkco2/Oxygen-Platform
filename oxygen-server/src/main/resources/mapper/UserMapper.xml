<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ethercraft.mapper.UserMapper">

    <insert id="createUser" parameterType="com.ethercraft.entity.User" useGeneratedKeys="true" keyProperty="id">
        insert into
        sys_user
        (username, password, nickname, email, phone, avatar, status)
        values (#{username}, #{password}, #{nickname}, #{email}, #{phone}, #{avatar}, #{status});
    </insert>

    <insert id="createUserRole">
        insert into
        sys_user_role(user_id, role_id)
        values
            <foreach collection="roleIds" item="roleId" separator=",">
                (#{userId}, #{roleId})
            </foreach>
    </insert>

</mapper>